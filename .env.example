# Copy to .env.local and fill secrets. Never commit .env.local.

# Neon Postgres (Vercel integration or Neon console)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Auth.js — generate: openssl rand -base64 32
AUTH_SECRET=replace-with-random-string
AUTH_URL=http://localhost:3000

# Groq — https://console.groq.com → API Keys
AI_PROVIDER=groq
GROQ_API_KEY=gsk_replace_me

# Optional: Vercel Blob
BLOB_READ_WRITE_TOKEN=

# Optional: Upstash Redis (REST)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- Vercel production (set in Vercel → Project → Settings → Environment Variables) ---
# Do not set NODE_ENV=development in Vercel; the platform sets production.
# AUTH_URL and NEXT_PUBLIC_APP_URL must be your real site URL, e.g. https://your-app.vercel.app
# DATABASE_URL: use Neon via Vercel Marketplace or paste from Neon dashboard (sslmode=require).
# Run db:push + db:seed once against that DB from your machine before or after first deploy.
