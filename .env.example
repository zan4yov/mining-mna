# =============================================================================
# PRODUCTION (Vercel) — set these in Vercel → Project → Settings → Environment Variables
# =============================================================================
# Do not use localhost here. Example production values:
#   AUTH_URL=https://mining-mna.vercel.app
#   NEXT_PUBLIC_APP_URL=https://mining-mna.vercel.app
# AUTH_SECRET: openssl rand -base64 32 (unique per project)
# DATABASE_URL: Neon pooled URL (Vercel Storage → Neon, or Neon console), sslmode=require

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL_UNPOOLED=

AUTH_SECRET=
AUTH_URL=https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

AI_PROVIDER=groq
GROQ_API_KEY=

BLOB_READ_WRITE_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# OPTIONAL: local development only — copy to .env.local (never commit .env.local)
# =============================================================================
# AUTH_URL=http://localhost:3000
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# next.config.mjs maps AUTH_URL → NEXTAUTH_URL for Auth.js client bundle
