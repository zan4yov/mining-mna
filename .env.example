# =============================================================================
# PRODUCTION (Vercel) — set these in Vercel → Project → Settings → Environment Variables
# =============================================================================
# Do not use localhost here. Example production values:
#   AUTH_URL=https://mining-mna.vercel.app
#   NEXT_PUBLIC_APP_URL=https://mining-mna.vercel.app
# AUTH_SECRET: openssl rand -base64 32 (unique per project)
# DATABASE_URL: Neon pooled URL (Vercel Storage → Neon, or Neon console), sslmode=require

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL_UNPOOLED=

AUTH_SECRET=
AUTH_URL=https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

AI_PROVIDER=groq
GROQ_API_KEY=

BLOB_READ_WRITE_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional one-time bootstrap (remove from env after first super_admin exists)
# SEED_ENABLE=true
# SEED_SUPER_ADMIN_EMAIL=
# SEED_SUPER_ADMIN_PASSWORD=
# SEED_SUPER_ADMIN_NAME=
# SEED_SUPER_ADMIN_TEAM=

# =============================================================================
# OPTIONAL: machine-only dev — copy to .env.local (never commit .env.local)
# =============================================================================
# Set AUTH_URL to your dev origin (e.g. http://127.0.0.1:3000). If NEXT_PUBLIC_APP_URL
# is omitted, next.config.mjs copies AUTH_URL → NEXT_PUBLIC_APP_URL + NEXTAUTH_URL.
# No localhost appears in application source code.
